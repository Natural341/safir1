d:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Service\",\"name\":\"İstanbul Malzemeli Profesyonel Temizlik Hizmeti\",\"description\":\"Safir Temizlik'in malzemeli temizlik hizmeti, tüm deterjan, ekipman ve temizlik malzemelerinin tarafımızdan sağlandığı kapsamlı bir hizmettir. HEPA filtreli vakum makineleri, buhar teknolojisi, anti-alerjen deterjanlar ve profesyonel temizlik ekipmanlarımızla evinize veya ofisinize geliyoruz. Siz sadece kapıyı açmanız yeterli.\",\"provider\":{\"@type\":\"LocalBusiness\",\"name\":\"Safir Temizlik\",\"telephone\":\"+905529475313\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"Atatürk Mah. Demokrasi Cad. Alaca Sk. No:37\",\"addressLocality\":\"Sancaktepe/İstanbul\",\"addressCountry\":\"TR\"}},\"areaServed\":{\"@type\":\"City\",\"name\":\"İstanbul\"},\"image\":\"https://safirtemizlik.com.tr/images/services/malzemeli.jpg\",\"url\":\"https://safirtemizlik.com.tr/hizmetler/malzemeli-temizlik\"}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Malzemeli temizlik fiyatı normal temizlikten farklı mı?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Evet, malzeme maliyeti dahil olduğu için standart temizliğe göre bir miktar fark vardır. Ancak kendi malzemenizi temin etme zahmetinden kurtulursunuz.\"}},{\"@type\":\"Question\",\"name\":\"Hangi marka deterjanlar kullanılıyor?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Profesyonel temizlik sektöründe güvenilen, çevre dostu ve anti-alerjen ürünler kullanıyoruz. Hassas cildiniz veya alerjiniz varsa bunu önceden belirtmeniz yeterlidir.\"}},{\"@type\":\"Question\",\"name\":\"Buhar temizliği her yüzeyde uygulanabilir mi?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Buhar temizliği fayans, seramik, mermer ve birçok yüzeyde güvenle uygulanır. Hassas yüzeyler için önceden değerlendirme yapılır.\"}}]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Ana Sayfa\",\"item\":\"https://safirtemizlik.com.tr\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Hizmetlerimiz\",\"item\":\"https://safirtemizlik.com.tr/services\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Malzemeli Temizlik\",\"item\":\"https://safirtemizlik.com.tr/hizmetler/malzemeli-temizlik\"}]}"}}],["$","main",null,{"className":"min-h-screen bg-white","children":[["$","section",null,{"className":"relative bg-slate-900 text-white pt-32 pb-20 overflow-hidden","children":[["$","div",null,{"className":"absolute inset-0","children":[["$","$L16",null,{"src":"/images/services/malzemeli.jpg","alt":"İstanbul Malzemeli Profesyonel Temizlik Hizmeti","fill":true,"priority":true,"className":"object-cover opacity-15","sizes":"100vw"}],["$","div",null,{"className":"absolute inset-0 bg-gradient-to-br from-purple-950/60 via-slate-900/80 to-slate-950"}]]}],["$","div",null,{"className":"max-w-7xl mx-auto px-6 relative z-10","children":[["$","div",null,{"className":"text-[10px] font-bold uppercase tracking-widest text-slate-400 flex gap-3 mb-10","children":[["$","$L17",null,{"href":"/","className":"hover:text-slate-200 transition-colors","children":"Ana Sayfa"}],["$","span",null,{"children":"/"}],["$","$L17",null,{"href":"/services","className":"hover:text-slate-200 transition-colors","children":"Hizmetlerimiz"}],["$","span",null,{"children":"/"}],["$","span",null,{"className":"text-slate-200","children":"Malzemeli Temizlik"}]]}],["$","div",null,{"className":"grid lg:grid-cols-2 gap-12 items-center","children":[["$","div",null,{"children":[["$","span",null,{"className":"text-purple-300/80 font-black tracking-[0.3em] uppercase text-[11px] mb-4 block","children":"Siz Sad